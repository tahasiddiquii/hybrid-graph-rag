# hybrid-graph-rag is fully offline by default — no keys required.
# These are only needed if you opt into the pluggable cloud/back-end extras.

# Optional: real dense embeddings via sentence-transformers (extra: dense)
# (no key required; model is downloaded locally on first use)
# HF_HOME=~/.cache/huggingface

# Optional: Neo4j-backed property graph (extra: graph)
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=
